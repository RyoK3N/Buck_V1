# Buck Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit a real .env — it is gitignored. Keep secrets out of this template.

# Required - Your LLM API key (OpenAI or OpenRouter)
OPENAI_API_KEY=

# Optional - Base URL for LLM API (leave empty for OpenAI default)
# For OpenRouter:
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional - LLM model to use
# OpenRouter examples: mistralai/mistral-nemo, microsoft/phi-3-mini-128k-instruct
# OpenAI examples: gpt-4o, gpt-4.1, gpt-4o-mini
CHAT_MODEL=gpt-4o

# Optional - Temperature for LLM (0.0 = deterministic)
TEMPERATURE=0.0

# Optional - Max tokens for completion
MAX_COMPLETION_TOKENS=1500

# Optional - Number of news items to fetch
NEWS_ITEMS=8

# Optional - News API key (for Indian stock news)
# Get your free key from https://stock.indianapi.in/
INDIAN_API_KEY=

# Optional - Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional - Output directory for results
OUTPUT_DIR=output

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Required only if you want to use Claude as a predictor or run the MCP server.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_THINKING_BUDGET=10000
CLAUDE_MAX_ITERATIONS=10
CLAUDE_SESSION_TOKEN_BUDGET=200000

# ── Accuracy tracking ────────────────────────────────────────────────────────
# SQLite database used to record predictions + actuals + evaluations.
ACCURACY_DB_PATH=accuracy/buck_accuracy.db
# How often the intraday poller fetches latest prices (minutes).
ACCURACY_POLL_INTERVAL_MINUTES=5
# Set to false to skip starting the APScheduler jobs (e.g. for CI / tests).
ACCURACY_SCHEDULER_ENABLED=true
# Market timezone + exchange for the trading-window calculation.
MARKET_TZ=Asia/Kolkata
MARKET_EXCHANGE=NSE

# ── Backend API auth (optional) ───────────────────────────────────────────────
# If set, every request to the FastAPI backend must carry
# `Authorization: Bearer <token>` (except GET /health). Leave empty for the
# default localhost-only workflow. Set this if the backend is reachable
# beyond localhost (e.g. behind a reverse proxy). Does NOT cover the
# /accuracy/ws WebSocket — see UI/backend/auth.py.
BUCK_API_AUTH_TOKEN=

# ── MCP server ────────────────────────────────────────────────────────────────
# HTTP port for the standalone MCP server (`python -m mcp_server.runner`).
MCP_HTTP_PORT=8765
# Set to true to mount the MCP server inside the FastAPI process under /mcp.
MOUNT_MCP_IN_API=false
# Base URLs the MCP tools use to drive and open the running Buck web app, so a
# replay session Claude starts shows up live in the UI. Point these at wherever
# `python main.py` serves the backend (API) and frontend (UI).
BUCK_API_URL=http://localhost:8000
BUCK_UI_URL=http://localhost:5173

# ── Context engineering (headroom compression layer) ─────────────────────────
# Compress MCP tool outputs before Claude sees them, to cut token usage.
HEADROOM_ENABLED=true
# USD price per 1M tokens, used to estimate the cost saved by compression.
# Default tracks Claude Opus input pricing; tune per model/deployment.
HEADROOM_PRICE_PER_MTOK=15.0
# LRU cache for idempotent read-only tool outputs.
HEADROOM_CACHE_TTL=300
HEADROOM_CACHE_MAXSIZE=256
# Skip compression for payloads below this many estimated tokens (small results /
# realtime steps never benefit and shouldn't exercise the headroom circuit breaker).
HEADROOM_MIN_TOKENS=800

# ── Real-time intraday simulation (python -m realtime.cli) ───────────────────
# Seconds between live-data polls during a session.
RT_POLL_SECONDS=30
# Run an online PPO update every N observed bars.
RT_ONLINE_UPDATE_EVERY=4
