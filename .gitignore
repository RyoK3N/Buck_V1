# ==============================================================================
# Python & Environment
# ==============================================================================
# Ignores all files inside any __pycache__ folder, anywhere in the project
**/__pycache__/*
*.py[cod]
*$py.class

# Environment files — ignore real secrets, but keep the committed template
.env
.env.*
!.env.example

# ==============================================================================
# Project Directories & Data
# ==============================================================================
# Keep the inputs directory, but ignore all files inside it.
# NOTE: this was previously "input/" (singular) — a typo that never matched
# the real "inputs/" directory, which is why debug prompt/JSON dumps ended
# up committed to the repo (see SECURITY.md).
inputs/*
!inputs/.gitkeep

# Keep the output directory, but ignore all files inside it
output/*
!output/.gitkeep

# Keep the weights directory, but ignore all files inside it
tools/rl/weights/*
!tools/rl/weights/.gitkeep

# LSTM checkpoint cache (keyed by data fingerprint — see tools/dl/lstm_prediction.py)
tools/dl/lstm_weights/*
!tools/dl/lstm_weights/.gitkeep

# Training-session run artifacts (keep the dir, ignore the JSON dumps)
tools/rl/sessions/*
!tools/rl/sessions/.gitkeep

# Runtime databases (accuracy tracking, etc.)
*.db
*.sqlite
*.sqlite3

# Build/Visualizer artifacts
buck_visualizer/data-viz/

# Claude Desktop extension bundles (build output of claude_extension/build.sh)
*.mcpb
*.dxt


# ==============================================================================
# Python build / tooling
# ==============================================================================
build/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# ==============================================================================
# Frontend (Node / Vite)
# ==============================================================================
# Dependencies — never commit these
**/node_modules/
# Build output
UI/frontend/dist/
**/dist/
# Vite caches & logs
**/.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# Editor / OS
# ==============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp