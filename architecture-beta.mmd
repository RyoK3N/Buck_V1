architecture-beta
    group pipeline[Pipeline]

    service yfinance(internet)[YahooFinance]
    service newsapi(internet)[NewsAPI]
    service openai(internet)[OpenAI]

    service providers(server)[DataProviders] in pipeline
    service tools(server)[AnalysisTools] in pipeline
    service analyzers(server)[Analyzers] in pipeline
    service predictor(server)[Predictor] in pipeline
    service agent(server)[StockAgent] in pipeline
    service cache(disk)[Cache] in pipeline
    service cli(server)[CLI] in pipeline

    yfinance:B -- T:providers
    newsapi:B -- T:tools
    openai:B -- T:predictor
    providers:B -- T:tools
    tools:B -- T:analyzers
    analyzers:B -- T:predictor
    predictor:B -- T:agent
    agent:R -- L:cache
    agent:B -- T:cli